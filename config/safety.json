{
  "automationEnabled": false,
  "practicalStartEnabled": true,
  "supportedLanguages": [
    "kor",
    "eng"
  ],
  "canonicalResolution": {
    "width": 1920,
    "height": 1080
  },
  "aspectRatioTolerance": 0.005,
  "startKey": "F1",
  "emergencyStopKey": "F2",
  "requiredWindowTitle": "Forza Horizon 6",
  "inputDelayMilliseconds": 750,
  "maxKeysPerOneShot": 32,
  "maxCycles": 1,
  "maxRuntimeMinutes": 15,
  "maxRecognitionRetriesPerPoint": 3,
  "maxDuplicateRetriesPerPoint": 2,
  "maxFullScanRetries": 2,
  "onUncertainRecognition": "retry_then_pause",
  "onDuplicateRecognition": "retry_nearby_then_next_point",
  "onFocusLost": "pause",
  "resumeAfterProcessRestart": false
}
